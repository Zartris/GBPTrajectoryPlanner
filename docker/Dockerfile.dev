# syntax=docker/dockerfile:1
# GBPTrajectoryPlanner Development Container
# Requires: DOCKER_BUILDKIT=1 (default in Docker 23+)
# See: https://docs.github.com/en/actions/creating-actions/dockerfile-support-for-github-actions

FROM debian:bookworm-slim

# ── Build args ──────────────────────────────────────────────────────
ARG USERNAME=esp
ARG CONTAINER_USER=${USERNAME}
ARG RUST_CHANNEL=stable
ARG ESP_BOARD=esp32c5

ENV DEBIAN_FRONTEND=noninteractive
ENV LC_ALL=C.UTF-8
ENV LANG=C.UTF-8

# ── 1. Core system packages ────────────────────────────────────────
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt/lists,sharing=locked \
    apt-get update && apt-get install -y \
        git \
        git-lfs \
        curl \
        ninja-build \
        llvm-dev \
        libclang-dev \
        clang \
        unzip \
        python3 \
        python3-pip \
        pkg-config \
        libssl-dev \
        sudo \
        tmux

# ── 2. Bevy / wgpu Linux dependencies (X11 + Wayland + GPU) ───────
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt/lists,sharing=locked \
    apt-get update && apt-get install -y \
        libx11-dev \
        libxi-dev \
        libxcursor-dev \
        libxrandr-dev \
        libxinerama-dev \
        libgl1-mesa-dev \
        libegl1-mesa-dev \
        libgles2-mesa-dev \
        libxkbcommon-dev \
        libxkbcommon-x11-0 \
        libwayland-dev

# ── 3. Node.js 22 ──────────────────────────────────────────────────
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt/lists,sharing=locked \
    curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs

# ── 4. GitHub CLI (auth config mounted from host via docker-compose)
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt/lists,sharing=locked \
    curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
        | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg \
    && chmod go+r /usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
        > /etc/apt/sources.list.d/github-cli.list \
    && apt-get update && apt-get install -y gh

# ── 5. Git LFS (system-wide) ──────────────────────────────────────
RUN git lfs install --system

# ── 6. Create non-root user with dialout/plugdev access ───────────
RUN adduser --disabled-password --gecos "" ${CONTAINER_USER} \
    && (groupadd -g 46 plugdev 2>/dev/null || true) \
    && usermod -aG dialout,plugdev ${CONTAINER_USER} \
    && echo "${CONTAINER_USER} ALL=(ALL:ALL) NOPASSWD: ALL" >> /etc/sudoers

# ── 7. Config files ───────────────────────────────────────────────
COPY --chown=${CONTAINER_USER}:${CONTAINER_USER} tmux.conf /home/${CONTAINER_USER}/.tmux.conf
COPY welcome.sh /usr/local/bin/trl-welcome
RUN chmod +x /usr/local/bin/trl-welcome

# ── Switch to non-root user ───────────────────────────────────────
USER ${CONTAINER_USER}
WORKDIR /home/${CONTAINER_USER}

ENV PATH=${PATH}:/home/${CONTAINER_USER}/.cargo/bin:/home/${CONTAINER_USER}/.local/bin
ENV NPM_CONFIG_PREFIX=/home/${CONTAINER_USER}/.npm-global
ENV PATH=/home/${CONTAINER_USER}/.npm-global/bin:$PATH

RUN mkdir -p /home/${CONTAINER_USER}/.npm-global /home/${CONTAINER_USER}/.local/bin

# ── 8. Rust toolchain ─────────────────────────────────────────────
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- \
        --default-toolchain ${RUST_CHANNEL} -y --profile minimal \
        --component rust-src,clippy,rustfmt \
        --target riscv32imac-unknown-none-elf

# ── 9. ESP-RS tools (espflash, cargo-espflash, web-flash) ─────────
RUN --mount=type=cache,target=/tmp/esp-dl,uid=1000 <<EOF
    set -eu
    ARCH=$(rustup show | grep "Default host" | sed -e 's/.* //')

    for TOOL in cargo-espflash espflash; do
        if [ ! -f "/tmp/esp-dl/${TOOL}-${ARCH}.zip" ]; then
            curl -L "https://github.com/esp-rs/espflash/releases/latest/download/${TOOL}-${ARCH}.zip" \
                -o "/tmp/esp-dl/${TOOL}-${ARCH}.zip"
        fi
        unzip -o "/tmp/esp-dl/${TOOL}-${ARCH}.zip" -d "${HOME}/.cargo/bin/"
    done

    if [ ! -f "/tmp/esp-dl/web-flash-${ARCH}.zip" ]; then
        curl -L "https://github.com/esp-rs/esp-web-flash-server/releases/latest/download/web-flash-${ARCH}.zip" \
            -o "/tmp/esp-dl/web-flash-${ARCH}.zip"
    fi
    unzip -o "/tmp/esp-dl/web-flash-${ARCH}.zip" -d "${HOME}/.cargo/bin/"
EOF

# ── 10. cargo-generate ─────────────────────────────────────────────
RUN --mount=type=cache,target=/tmp/esp-dl,uid=1000 <<EOF
    set -eu
    ARCH=$(rustup show | grep "Default host" | sed -e 's/.* //')
    VERSION=$(git ls-remote --refs --sort="version:refname" --tags "https://github.com/cargo-generate/cargo-generate" | cut -d/ -f3- | tail -n1)
    TARBALL="cargo-generate-${VERSION}-${ARCH}.tar.gz"
    if [ ! -f "/tmp/esp-dl/${TARBALL}" ]; then
        curl -L "https://github.com/cargo-generate/cargo-generate/releases/latest/download/${TARBALL}" \
            -o "/tmp/esp-dl/${TARBALL}"
    fi
    tar xf "/tmp/esp-dl/${TARBALL}" -C "${HOME}/.cargo/bin/"
EOF

# ── 11. probe-rs (flash + debug over USB) ──────────────────────────
RUN curl -LsSf https://github.com/probe-rs/probe-rs/releases/latest/download/probe-rs-tools-installer.sh | sh

# ── 12. AI coding assistants ──────────────────────────────────────
# Claude Code
RUN curl -fsSL https://claude.ai/install.sh | bash
# GitHub Copilot CLI
RUN curl -fsSL https://gh.io/copilot-install | bash
# OpenCode
RUN curl -fsSL https://opencode.ai/install | bash

# ── Entry ──────────────────────────────────────────────────────────
WORKDIR /workspace
CMD ["/bin/bash"]
