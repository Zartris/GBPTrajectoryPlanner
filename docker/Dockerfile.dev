# syntax=docker/dockerfile:1
# GBPTrajectoryPlanner Development Container
# Requires: DOCKER_BUILDKIT=1 (default in Docker 23+)
# See: https://docs.github.com/en/actions/creating-actions/dockerfile-support-for-github-actions

FROM ubuntu:24.04

# ── Build args ──────────────────────────────────────────────────────
ARG USERNAME=esp
ARG CONTAINER_USER=${USERNAME}
ARG USER_UID=1000
ARG USER_GID=1000
ARG RENDER_GID=992
ARG RUST_CHANNEL=stable
ARG ESP_BOARD=esp32c5

ENV DEBIAN_FRONTEND=noninteractive
ENV LC_ALL=C.UTF-8
ENV LANG=C.UTF-8

# ── 1. Core system packages ────────────────────────────────────────
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt/lists,sharing=locked \
    apt-get update && apt-get install -y \
        git \
        git-lfs \
        curl \
        ninja-build \
        llvm-dev \
        libclang-dev \
        clang \
        unzip \
        python3 \
        python3-pip \
        pkg-config \
        libssl-dev \
        sudo \
        tmux

# ── 2. Bevy / wgpu Linux dependencies (X11 + Wayland + GPU) ───────
# Kisak Mesa PPA provides the dzn (D3D12-over-Vulkan) driver needed for
# GPU-accelerated Vulkan in WSL2 — Ubuntu's stock Mesa omits it.
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt/lists,sharing=locked \
    apt-get update && apt-get install -y software-properties-common \
    && add-apt-repository -y ppa:kisak/kisak-mesa \
    && apt-get update && apt-get install -y \
        libx11-dev \
        libxi-dev \
        libxcursor-dev \
        libxrandr-dev \
        libxinerama-dev \
        libgl1-mesa-dev \
        libgl1-mesa-dri \
        libegl1-mesa-dev \
        libegl-mesa0 \
        libgles2-mesa-dev \
        mesa-utils \
        mesa-vulkan-drivers \
        libvulkan1 \
        libvulkan-dev \
        vulkan-tools \
        vulkan-validationlayers \
        libdrm-dev \
        libxkbcommon-dev \
        libxkbcommon-x11-0 \
        libwayland-dev

# ── 3. Node.js 22 ──────────────────────────────────────────────────
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt/lists,sharing=locked \
    curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs

# ── 4. GitHub CLI (auth config mounted from host via docker-compose)
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt/lists,sharing=locked \
    curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
        | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg \
    && chmod go+r /usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
        > /etc/apt/sources.list.d/github-cli.list \
    && apt-get update && apt-get install -y gh

# ── 5. Git LFS (system-wide) ──────────────────────────────────────
RUN git lfs install --system

# ── 6. Create non-root user with dialout/plugdev access ───────────
# Ubuntu 24.04 ships a default 'ubuntu' user at uid 1000 — remove it
# so our user can claim that uid (needed for bind-mount permissions).
RUN (userdel -r ubuntu 2>/dev/null || true) \
    && (groupdel ubuntu 2>/dev/null || true) \
    && (groupadd -g ${USER_GID} ${CONTAINER_USER} 2>/dev/null || true) \
    && adduser --disabled-password --gecos "" --uid ${USER_UID} --gid ${USER_GID} ${CONTAINER_USER} \
    && (groupadd -g 46 plugdev 2>/dev/null || true) \
    && (groupmod -g ${RENDER_GID} render 2>/dev/null || groupadd -g ${RENDER_GID} render 2>/dev/null || true) \
    && usermod -aG dialout,plugdev,video,render ${CONTAINER_USER} \
    && echo "${CONTAINER_USER} ALL=(ALL:ALL) NOPASSWD: ALL" >> /etc/sudoers

# ── 7. Config files ───────────────────────────────────────────────
COPY --chown=${CONTAINER_USER}:${CONTAINER_USER} tmux.conf /home/${CONTAINER_USER}/.tmux.conf
COPY welcome.sh /usr/local/bin/trl-welcome
RUN chmod +x /usr/local/bin/trl-welcome

# ── Switch to non-root user ───────────────────────────────────────
USER ${CONTAINER_USER}
WORKDIR /home/${CONTAINER_USER}

ENV PATH=${PATH}:/home/${CONTAINER_USER}/.cargo/bin:/home/${CONTAINER_USER}/.local/bin
ENV NPM_CONFIG_PREFIX=/home/${CONTAINER_USER}/.npm-global
ENV PATH=/home/${CONTAINER_USER}/.npm-global/bin:$PATH

RUN mkdir -p /home/${CONTAINER_USER}/.npm-global /home/${CONTAINER_USER}/.local/bin \
    && mkdir -p /tmp/runtime-1000 && chmod 700 /tmp/runtime-1000

# ── 8. Rust toolchain ─────────────────────────────────────────────
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- \
        --default-toolchain ${RUST_CHANNEL} -y --profile minimal \
        --component rust-src,clippy,rustfmt \
        --target riscv32imac-unknown-none-elf

# ── 9. cargo-binstall (binary installer for cargo tools) ───────────
RUN curl -fsSL https://raw.githubusercontent.com/cargo-bins/cargo-binstall/main/install-from-binstall-release.sh | bash

# ── 10. ESP-RS tools (espflash from git — needs unreleased ESP32-C5 support)
RUN cargo install espflash --git https://github.com/esp-rs/espflash

# ── 10b. cargo-generate ───────────────────────────────────────────
RUN cargo binstall -y --no-symlinks cargo-generate

# ── 11. probe-rs (flash + debug over USB) ──────────────────────────
RUN curl -LsSf https://github.com/probe-rs/probe-rs/releases/latest/download/probe-rs-tools-installer.sh | sh

# ── 12. AI coding assistants ──────────────────────────────────────
# Claude Code
RUN curl -fsSL https://claude.ai/install.sh | bash
# GitHub Copilot CLI
# RUN curl -fsSL https://gh.io/copilot-install | bash
# # OpenCode
# RUN curl -fsSL https://opencode.ai/install | bash

# ── Entry ──────────────────────────────────────────────────────────
WORKDIR /workspace
CMD ["/bin/bash"]
