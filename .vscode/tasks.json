{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "type": "shell",
      "command": "cargo build --release",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": [
        "$rustc"
      ]
    },
    {
      "label": "build-debug",
      "command": "cargo build",
      "type": "shell",
    },
    {
      "label": "flash-to-device",
      "type": "shell",
      "command": "bash scripts/flash-device.sh",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "clear": true
      },
      "runOptions": {
        "instanceLimit": 999
      },
      "problemMatcher": []
    },
    {
      "label": "monitor",
      "type": "shell",
      "command": "bash scripts/monitor.sh",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "clear": true
      },
      "runOptions": {
        "instanceLimit": 999
      },
      "problemMatcher": []
    },
    {
      "label": "flash-all",
      "type": "shell",
      "command": "bash scripts/flash-all.sh",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    }
  ]
}